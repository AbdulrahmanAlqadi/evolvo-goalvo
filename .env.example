п»ҝ# Application
APP_ENV=development
APP_NAME=Arabic Football Forecast Agent
APP_HOST=127.0.0.1
APP_PORT=8000
APP_TIMEZONE=UTC
LOG_LEVEL=INFO
LOG_FORMAT=json

# Persistence
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# API security
API_AUTH_ENABLED=true
API_KEY=change-me
EXPOSE_DEBUG_DETAILS=false
ALLOWED_HOSTS=127.0.0.1,localhost,testserver
CORS_ORIGINS=
MAX_REQUEST_BYTES=1048576
API_RATE_LIMIT_REQUESTS=120
API_RATE_LIMIT_WINDOW_SECONDS=60

# Football providers
FOOTBALL_PROVIDER=worldcup26
FOOTBALL_PROVIDER_FALLBACKS=api_football,football_data_org,thesportsdb,replay,mock
FOOTBALL_REQUEST_TIMEOUT_SECONDS=10
FOOTBALL_MAX_RETRIES=2
FOOTBALL_ALLOWED_HOSTS=v3.football.api-sports.io,api.football-data.org,www.thesportsdb.com,worldcup26.ir
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_DAILY_BUDGET=100
API_FOOTBALL_MINUTE_BUDGET=10
API_FOOTBALL_COMPETITION_ID=1
API_FOOTBALL_SEASON=2026
FOOTBALL_DATA_ORG_KEY=
FOOTBALL_DATA_ORG_BASE_URL=https://api.football-data.org/v4
THESPORTSDB_KEY=3
THESPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json
WORLDCUP26_BASE_URL=https://worldcup26.ir
SPORTMONKS_KEY=
WORLD_CUP_ONLY=true
WORLD_CUP_COMPETITION_IDS=worldcup26:2026,worldcup26:competition:2026,replay:wc-2026,wc-2026,api_football:1,football_data_org:WC,thesportsdb:4429
WORLD_CUP_COMPETITION_ALIASES=FIFA World Cup,World Cup,Coupe du Monde,Copa Mundial,ГҷЖ’ГҳВЈГҳВі ГҳВ§ГҷвҖһГҳВ№ГҳВ§ГҷвҖһГҷвҖҰ,ГҷЖ’ГҳВ§ГҳВі ГҳВ§ГҷвҖһГҳВ№ГҳВ§ГҷвҖһГҷвҖҰ,ГҷЖ’ГҳВЈГҳВі ГҳВ§ГҷвҖһГҳВ№ГҳВ§ГҷвҖһГҷвҖҰ ГҷвҖһГҷЖ’ГҳВұГҳВ© ГҳВ§ГҷвҖһГҷвҖҡГҳВҜГҷвҖҰ
TEAM_LOCALIZATION_PATH=./configs/team_localization_ar.json

# Cache and live coordination
CACHE_ENABLED=true
CACHE_STATIC_TTL_SECONDS=86400
CACHE_FIXTURES_TTL_SECONDS=300
CACHE_LIVE_TTL_SECONDS=15
LIVE_POLLING_ENABLED=false
LIVE_POLL_INTERVAL_SECONDS=30
LIVE_POLL_MIN_INTERVAL_SECONDS=15
LIVE_POLL_MAX_INTERVAL_SECONDS=120
LIVE_DATA_STALE_AFTER_SECONDS=90
LIVE_RECOMPUTE_ON_EVENT=true
LIVE_RECOMPUTE_ON_STATS_CHANGE=true
LIVE_NOTIFICATION_MIN_DELTA=0.08
LIVE_NOTIFICATION_COOLDOWN_SECONDS=300

# Forecasting
PREDICTION_MODE=ensemble
MODEL_REGISTRY_PATH=./data/models/registry.json
PREMATCH_MODEL_VERSION=prematch-ensemble-v1
LIVE_MODEL_VERSION=live-simulation-v1
CALIBRATION_VERSION=identity-v1
ALLOW_UNCALIBRATED_FALLBACK=true
SIMULATION_COUNT=10000
SIMULATION_SEED=2026
MAX_SCORE_GOALS=10
ENSEMBLE_ELO_WEIGHT=0.35
ENSEMBLE_POISSON_WEIGHT=0.45
ENSEMBLE_CLASSIFIER_WEIGHT=0.20
DIXON_COLES_RHO=-0.08
MARKET_PRIOR_ENABLED=false
QUALITATIVE_CONTEXT_ENABLED=false

# LLM explanation layer (numerical predictions do not depend on this)
LLM_ENABLED=false
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_FALLBACK_PROVIDERS=openai,anthropic,openai_compatible
LLM_TIMEOUT_SECONDS=20
LLM_MAX_RETRIES=1
LLM_TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=700
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_KEY_SELECTION_STRATEGY=least_recently_used
GEMINI_KEY_COOLDOWN_SECONDS=60
GEMINI_MAX_ATTEMPTS_PER_REQUEST=2
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
COHERE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_MODE=polling
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ADMIN_USER_IDS=
TELEGRAM_NOTIFICATION_MIN_DELTA=0.08
TELEGRAM_NOTIFICATION_COOLDOWN_SECONDS=300
TELEGRAM_RATE_LIMIT_PER_MINUTE=30

# Arabic UX
ARABIC_DIGITS_ENABLED=false
ARABIC_EXPLANATION_STYLE=concise
ARABIC_DISCLAIMER_ENABLED=true

# Replay/testing
REPLAY_MODE=false
REPLAY_FIXTURE_PATH=./data/replay/sample_match.json
MOCK_CLOCK_ENABLED=false
